{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Factory Simulator (real_time)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Factory Simulator (fast, 25 steps)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--mode", "fast", "--max-steps", "25"],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Unit Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["discover", "-s", "tests", "-q"],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
